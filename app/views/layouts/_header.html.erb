<header class="bg-gray-50 border-b border-gray-200" data-controller="mobile-menu">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between relative">

      <div class="flex items-center">
        <%= link_to root_path do %>
          <%= cloud_image_tag "logo_mini.png", class: 'w-[80px] h-[50px]', alt: t('images.alt.logo_mini') %>
        <% end %>
        <div class="hidden lg:ml-10 lg:flex space-x-4">
          <% if current_user.present? %>
            <%= nav_link_to t('links.activities'),
              root_path, class: 'hover:text-gray-700 px-3 py-2 rounded-md text-sm font-medium text-gray-900' %>
            <%= nav_link_to t('links.statistics'),
              '#', class: 'hover:text-gray-700 px-3 py-2 rounded-md text-sm font-medium text-gray-900' %>
            <%= nav_link_to t('links.competition'),
              '#', class: 'hover:text-gray-700 px-3 py-2 rounded-md text-sm font-medium text-gray-900' %>
            <%= nav_link_to t('links.rating'),
              '#', class: 'hover:text-gray-700 px-3 py-2 rounded-md text-sm font-medium text-gray-900' %>
            <%= nav_link_to t('links.about_team'),
              about_team_path, class: 'hover:text-gray-700 px-3 py-2 rounded-md text-sm font-medium text-gray-900' %>
          <% else %>
            <%= nav_link_to t('links.root'),
              welcome_index_path, class: 'hover:text-gray-700 px-3 py-2 rounded-md text-sm font-medium text-gray-900' %>
            <%= nav_link_to t('links.about_team'),
              about_team_path,
              class: "hover:text-gray-700 px-3 py-2 rounded-md text-sm font-medium text-gray-900" %>
          <% end %>
        </div>
      </div>

      <div class="flex-1 flex justify-center px-2 lg:ml-6 lg:justify-end">
        <div class="w-full max-w-lg lg:max-w-xs relative">
          <div class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" clip-rule="evenodd"
                    d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z"/>
            </svg>
          </div>
          <input type="search" name="search" id="search"
                 class="block w-full rounded-md border border-gray-300 bg-white py-2 pl-10 pr-3 leading-5 text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-1 focus:ring-teal-700 focus:border-teal-700 sm:text-sm"
                 placeholder="Поиск">
        </div>
      </div>

      <button
        type="button"
        data-action="click->mobile-menu#toggle"
        class="lg:hidden inline-flex items-center justify-center rounded-md bg-gray-50 p-2 text-gray-400 hover:bg-gray-100 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 focus:ring-offset-gray-50"
      >
        <span class="sr-only">Open main menu</span>
        <svg data-mobile-menu-target="iconOpen" class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none"
             viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
        </svg>
        <svg data-mobile-menu-target="iconClose" class="hidden h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none"
             viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      
      <% if current_user.present? %>
        <div class="hidden lg:flex items-center lg:ml-4">
          <button class="p-1 text-gray-400 rounded-full hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-teal-600 focus:ring-offset-2">
            <span class="sr-only">Уведомления</span>
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a3 3 0 11-5.714 0"/>
            </svg>
          </button>
          <div class="ml-3 relative group">
            <button
              class="flex rounded-full bg-gray-50 text-sm focus:outline-none focus:ring-2 focus:ring-teal-600 focus:ring-offset-2">
              <% if current_user.avatar.attached? %>
                <%= image_tag(current_user.avatar, class: 'h-8 w-8 rounded-full', alt: 'Аватарка') %>
              <% else %>
                <%= cloud_image_tag 'default_avatar.jpg', alt: "Аватарка", class: "h-8 w-8 rounded-full" %>
              <% end %>
            </button>
            <div
              class="absolute right-0 z-10 mt-2 w-48 rounded-md bg-white shadow-lg border border-gray-100 ring-1 ring-black ring-opacity-5 opacity-0 scale-95 group-hover:opacity-100 group-hover:scale-100 transition-all duration-150 origin-top-right">
              <%= link_to t('links.find_friends'),
                users_path, 
                class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100' %>
              <%= link_to t('links.profile'),
                user_path(current_user), 
                class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100' %>
              <%= link_to t('links.log_out'), 
                destroy_user_session_path,
                method: :delete,
                class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100', 
                data: { turbo: false } %>
            </div>
          </div>
        </div>
      <% else %>
        <%= link_to t('links.sign_in'),
          new_user_session_path,
          class: 'text-white text-sm font-semibold py-2 px-4 rounded bg-teal-700 hover:bg-teal-700/75' %>
      <% end %>
    </div>
  </div>

  <div data-mobile-menu-target="menu" class="hidden lg:hidden border-t border-gray-200 bg-gray-50">
    <div class="space-y-1 px-2 pt-2 pb-3">
      <% if current_user.present? %>
        <%= link_to t('links.activities'),
          root_path, class: 'hover:bg-gray-100 block px-3 py-2 rounded-md font-medium text-gray-900' %>
        <%= link_to t('links.statistics'),
          '#', class: 'hover:bg-gray-100 block px-3 py-2 rounded-md font-medium text-gray-900' %>
        <%= link_to t('links.competition'),
          '#', class: 'hover:bg-gray-100 block px-3 py-2 rounded-md font-medium text-gray-900' %>
        <%= link_to t('links.rating'),
          '#', class: 'hover:bg-gray-100 block px-3 py-2 rounded-md font-medium text-gray-900' %>
        <%= link_to t('links.about_team'),
          about_team_path, class: 'hover:bg-gray-100 block px-3 py-2 rounded-md font-medium text-gray-900' %>
      <% else %>
        <%= link_to t('links.root'),
          root_path, class: 'hover:bg-gray-100 block px-3 py-2 rounded-md font-medium text-gray-900' %>
        <%= link_to t('links.about_team'),
          about_team_path,
          class: "hover:bg-gray-100 block px-3 py-2 rounded-md font-medium text-gray-900" %>
      <% end %>
    </div>
    <% if current_user.present? %>
      <div class="border-t border-gray-200 pt-4 pb-3 px-5">
        <div class="flex items-center">
          <% if current_user.avatar.attached? %>
            <%= image_tag(current_user.avatar, class: 'h-10 w-10 rounded-full', alt: 'Аватарка') %>
          <% else %>
            <%= cloud_image_tag 'default_avatar.jpg', alt: "Аватарка", class: "h-10 w-10 rounded-full" %>
          <% end %>
          <div class="ml-3">
            <div class="text-base font-medium text-gray-800"><%= current_user.short_name %></div>
            <div class="text-sm font-medium text-gray-500"><%= current_user.email %></div>
          </div>
        </div>
        <div class="mt-3 space-y-1">
          <%= link_to t('links.find_friends'),
            users_path, 
            class: 'block rounded-md py-2 px-3 text-base font-medium text-gray-900 hover:bg-gray-100' %>
          <%= link_to t('links.profile'),
            user_path(current_user), class: 'block rounded-md py-2 px-3 text-base font-medium text-gray-900 hover:bg-gray-100' %>
          <%= link_to t('links.log_out'),
            destroy_user_session_path,
            method: :delete,
            class: 'block rounded-md py-2 px-3 text-base font-medium text-gray-900 hover:bg-gray-100',
            data: { turbo: false } %>
        </div>
      </div>
    <% end %>
  </div>
</header>
