<!DOCTYPE html>
<html>
<head>
  <title>GrizzledBearTeam</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta property="og:title" content="GrizzledBear" />
  <meta property="og:description" content="Join to GrizzledBearTeam" />
  <meta property="og:image" content="https://grizzledbear-team.ru/preview.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:url" content="https://grizzledbear-team.ru" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="GrizzledBear" />
  <meta name="twitter:description" content="Join to GrizzledBearTeam" />
  <meta name="twitter:image" content="https://grizzledbear-team.ru/preview.jpg" />

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= vite_stylesheet_tag "data-turbo-track": "reload" %>
  <%= vite_client_tag %>
  <%= vite_javascript_tag 'application', "data-turbo-track": "reload" %>
</head>
<body class="overflow-x-hidden">
<div class="flex flex-col">
  <%= render "shared/flash" if flash.present? %>
  <header>
    <%= render 'layouts/header' %>
  </header>
  <main>    
    <%= yield %>
  </main>
  <footer>
    <div class="h-[500px]">
      <%= render 'layouts/footer' %>
    </div>
  </footer>
</div>
</body>
</html>
