<div class="flex px-2 sm:px-6 py-4 border-t border-gray-200">
 <div class="w-1/5">
   <% if comment.user.avatar.attached? %>
     <%= image_tag comment.user.avatar, class: "h-10 sm:h14 rounded-full", alt: 'Аватарка' %>
   <% else %>
     <%= cloud_image_tag 'default_avatar.jpg', alt: "#{comment.user.short_name} аватар", class: "h-10 sm:h14 rounded-full" %>
   <% end %>
 </div>
  <div class="flex flex-col w-full">
    <div class="flex justify-between">
      <div class="font-bold text-sm text-gray-800"><%= comment.user.short_name %></div>
      <div class="text-[12px] sm:text-sm text-gray-600"><%= comment.created_at.strftime('%d.%m.%Y %H:%M:%S') %></div>
    </div>
    <div class="text-sm mt-2"><%= comment.body %></div>
  </div>
</div>
