<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Заголовок -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Статистика</h1>
      <p class="mt-2 text-sm text-gray-600">Ваши достижения и прогресс в тренировках</p>
    </div>

    <!-- Общая статистика -->
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4 mb-8">
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Всего заездов</dt>
                <dd class="text-3xl font-semibold text-gray-900"><%= @total_rides %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Общая дистанция</dt>
                <dd class="text-3xl font-semibold text-gray-900"><%= @total_distance %> <span class="text-lg">км</span></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Время в движении</dt>
                <dd class="text-3xl font-semibold text-gray-900"><%= @total_duration %> <span class="text-lg">ч</span></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Сожжено калорий</dt>
                <dd class="text-3xl font-semibold text-gray-900"><%= (@total_distance * 35).round %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Статистика по типам заездов -->
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 mb-8">
      <!-- Велозаезд -->
      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-5 border-b border-gray-200">
          <h3 class="text-lg leading-6 font-medium text-gray-900 flex items-center">
            <span class="inline-flex items-center justify-center h-10 w-10 rounded-md bg-teal-500 text-white mr-3">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
            </span>
            Велозаезд
          </h3>
        </div>
        <div class="px-6 py-5">
          <dl class="grid grid-cols-2 gap-5">
            <div>
              <dt class="text-sm font-medium text-gray-500">Количество заездов</dt>
              <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @cycling_stats[:rides_count] %></dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">Общая дистанция</dt>
              <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @cycling_stats[:total_distance] %> км</dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">Средняя скорость</dt>
              <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @cycling_stats[:avg_speed] %> км/ч</dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">Макс. скорость</dt>
              <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @cycling_stats[:max_speed] %> км/ч</dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">Набор высоты</dt>
              <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @cycling_stats[:total_elevation] %> м</dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">Самый длинный заезд</dt>
              <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @cycling_stats[:longest_ride] %> км</dd>
            </div>
          </dl>
        </div>
      </div>

      <!-- Виртуальный велозаезд -->
      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-5 border-b border-gray-200">
          <h3 class="text-lg leading-6 font-medium text-gray-900 flex items-center">
            <span class="inline-flex items-center justify-center h-10 w-10 rounded-md bg-purple-500 text-white mr-3">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </span>
            Виртуальный велозаезд
          </h3>
        </div>
        <div class="px-6 py-5">
          <dl class="grid grid-cols-2 gap-5">
            <div>
              <dt class="text-sm font-medium text-gray-500">Количество заездов</dt>
              <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @virtual_cycling_stats[:rides_count] %></dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">Общая дистанция</dt>
              <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @virtual_cycling_stats[:total_distance] %> км</dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">Средняя скорость</dt>
              <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @virtual_cycling_stats[:avg_speed] %> км/ч</dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">Макс. скорость</dt>
              <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @virtual_cycling_stats[:max_speed] %> км/ч</dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">Набор высоты</dt>
              <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @virtual_cycling_stats[:total_elevation] %> м</dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">Самый длинный заезд</dt>
              <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @virtual_cycling_stats[:longest_ride] %> км</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>

    <!-- График по месяцам -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-6 py-5 border-b border-gray-200">
        <h3 class="text-lg leading-6 font-medium text-gray-900">Активность за последние 6 месяцев</h3>
      </div>
      <div class="px-6 py-5">
        <div class="space-y-6">
          <% @monthly_data.each do |month_data| %>
            <div>
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-gray-700"><%= month_data[:name] %></span>
                <span class="text-sm text-gray-500"><%= month_data[:cycling] + month_data[:virtual_cycling] %> км</span>
              </div>
              <div class="relative pt-1">
                <% total = month_data[:cycling] + month_data[:virtual_cycling] %>
                <% cycling_percent = total > 0 ? (month_data[:cycling].to_f / total * 100).round : 0 %>
                <% virtual_percent = total > 0 ? (month_data[:virtual_cycling].to_f / total * 100).round : 0 %>
                
                <div class="flex mb-2 items-center justify-between">
                  <div class="flex space-x-4">
                    <span class="text-xs font-semibold inline-block text-teal-600 flex items-center">
                      <span class="w-3 h-3 bg-teal-500 rounded-full mr-1"></span>
                      Велозаезд: <%= month_data[:cycling] %> км
                    </span>
                    <span class="text-xs font-semibold inline-block text-purple-600 flex items-center">
                      <span class="w-3 h-3 bg-purple-500 rounded-full mr-1"></span>
                      Виртуальный: <%= month_data[:virtual_cycling] %> км
                    </span>
                  </div>
                </div>
                <div class="overflow-hidden h-4 text-xs flex rounded bg-gray-200">
                  <div style="width:<%= cycling_percent %>%" class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-teal-500"></div>
                  <div style="width:<%= virtual_percent %>%" class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-purple-500"></div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Достижения -->
    <div class="mt-8 bg-white shadow rounded-lg">
      <div class="px-6 py-5 border-b border-gray-200">
        <h3 class="text-lg leading-6 font-medium text-gray-900">Достижения</h3>
      </div>
      <div class="px-6 py-5">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="text-center p-4 bg-yellow-50 rounded-lg">
            <div class="text-3xl mb-2">🏆</div>
            <div class="text-sm font-medium text-gray-900">Первый заезд</div>
          </div>
          <div class="text-center p-4 bg-blue-50 rounded-lg">
            <div class="text-3xl mb-2">🚴</div>
            <div class="text-sm font-medium text-gray-900">100 км</div>
          </div>
          <div class="text-center p-4 bg-green-50 rounded-lg">
            <div class="text-3xl mb-2">⭐</div>
            <div class="text-sm font-medium text-gray-900">10 заездов</div>
          </div>
          <div class="text-center p-4 bg-purple-50 rounded-lg">
            <div class="text-3xl mb-2">🎯</div>
            <div class="text-sm font-medium text-gray-900">Цель месяца</div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>
