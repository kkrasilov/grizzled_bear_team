<%= form_for @activity || Activity.new, html: { multipart: true }, data: { turbo: false } do |f| %>
  <div class="lg:col-span-2">
    <div class="grid gap-4 gap-y-2 text-sm grid-cols-1 md:grid-cols-5">

      <div class="md:col-span-5">
        <%= f.label :title, class: 'text-gray-700' %>
        <%= f.text_field :title, class: 'h-10 border border-gray-200 text-gray-600 mt-1 px-4 w-full focus:outline-teal-700' %>
      </div>

      <div class="md:col-span-5 flex gap-1">
        <div>
          <%= f.label :distance, class: 'text-gray-700' %>
          <%= f.number_field :distance, step: 0.01, class: 'h-10 border border-gray-200 text-gray-600 mt-1 px-4 w-full focus:outline-teal-700' %>
        </div>
        <div>
          <%= f.label :elevation, class: 'text-gray-700' %>
          <%= f.number_field :elevation, step: 1, class: 'h-10 border border-gray-200 text-gray-600 mt-1 px-4 w-full focus:outline-teal-700' %>
        </div>
      </div>

      <div class="md:col-span-5 w-[300px]">
        <%= f.label :duration, "Продолжительность", class: 'text-gray-700' %>
        <div class="flex mt-1 overflow-hidden border border-gray-200 w-full">
          <%= f.number_field :duration_hours,
            placeholder: "01 ч.",
            class: 'h-10 text-gray-600 px-2 w-1/3 border-r border-gray-200 focus:outline-none' %>
          <%= f.number_field :duration_minutes,
            placeholder: "00 мин.",
            class: 'h-10 text-gray-600 px-2 w-1/3 border-r border-gray-200 focus:outline-none' %>
          <%= f.number_field :duration_seconds,
            placeholder: "00 сек.",
            class: 'h-10 text-gray-600 px-2 w-1/3 focus:outline-none' %>
        </div>
      </div>

      <div class="md:col-span-5">
        <%= f.label :start_time, class: 'text-gray-700' %>
        <%= f.datetime_select :start_time, class: 'border border-gray-200 text-gray-600 mt-1 px-4 w-full focus:outline-teal-700' %>
      </div>

      <div class="md:col-span-5 w-[300px]">
        <%= f.label :category, class: 'text-gray-700' %>
        <%= f.select :category, Activity.categories.keys.map { [I18n.t("activerecord.attributes.activity.categories.#{_1}"), _1] }, {}, class: 'h-10 border border-gray-200 text-gray-600 mt-1 px-4 w-full focus:outline-teal-700' %>
      </div>

      <div class="md:col-span-5 w-[300px]">
        <%= f.label :ride_type, class: 'text-gray-700' %>
        <%= f.select :ride_type, Activity.ride_types.keys.map { [I18n.t("activerecord.attributes.activity.ride_types.#{_1}"), _1] }, {}, class: 'h-10 border border-gray-200 text-gray-600 mt-1 px-4 w-full focus:outline-teal-700' %>
      </div>

      <div class="md:col-span-5">
        <%= f.label :description, class: 'text-gray-700' %>
        <%= f.text_area :description, rows: 5, class: 'border border-gray-200 text-gray-600 mt-1 px-4 w-full focus:outline-teal-700' %>
      </div>

      <div class="md:col-span-5 text-right">
        <div class="inline-flex items-end">
          <%= f.submit t('links.save'), class: 'cursor-pointer text-white bg-teal-700 hover:bg-teal-700/75 focus:ring-4 
              focus:outline-none focus:ring-blue-300 font-medium rounded-sm text-sm w-full sm:w-auto 
              px-5 py-2.5 text-center' %>
        </div>
      </div>
    </div>
  </div>
<% end %>
