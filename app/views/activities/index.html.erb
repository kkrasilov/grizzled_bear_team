<div class="pt-6 pb-6 min-h-[calc(100vh-15rem)] border-b-1 border-gray-200 w-screen bg-gray-50">
  <div class="flex flex-wrap justify-center mx-auto w-7/8">
    <div class="hidden xl:block lg:w-1/3 xl:w-1/3 flex justify-center">
      <%= render "activities/user_card" %>
    </div>
    <div class="w-full lg:w-2/3 mt-4">
      <div class="border-b-1 border-gray-200 pb-6">
        <%= link_to t('links.create_activity'),
          new_activity_path,
          class: 'text-white text-sm font-semibold py-3 px-5 rounded bg-teal-700 hover:bg-teal-700/75' %>
      </div>
      <div class="flex flex-col gap-4 items-center mt-4">
        <% @activities.each do |activity| %>
          <%= render "activities/activity_card", activity: activity %>
        <% end %>
      </div>
    </div>
  </div>
</div>

