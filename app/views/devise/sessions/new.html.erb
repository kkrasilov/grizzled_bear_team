<div class="bg-cover bg-center lg:bg-left z-0 w-screen h-screen"
     style="background-image: url('<%= vite_asset_path('images/background/session_new.jpg') %>')">
  <div class="flex flex-col items-center flex-1 h-full justify-center px-4 sm:px-0">
    <div class="flex shadow-lg w-7/8 sm:w-3/4 lg:w-3/12 bg-white/85 sm:mx-0 p-10">
      <div class="flex flex-col flex-1 justify-center mb-8">
        <h1 class="text-4xl text-center font-thin">Войти</h1>
        <div class="w-full mt-4">
          <%= form_for(resource, as: resource_name, url: session_path(resource_name), data: { turbo: false }) do |f| %>
            <div class="form-horizontal w-3/4 mx-auto">
              <div class="sm:col-span-3">
                <%= f.label :email, class: 'block text-sm/6 font-medium text-gray-900' %>
                <%= f.email_field :email, autofocus: true, autocomplete: "email",
                  class: 'w-full mt-2 bg-white px-3 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-teal-600 sm:text-sm' %>
              </div>

              <div class="sm:col-span-3">
                <%= f.label :password, class: 'block text-sm/6 font-medium text-gray-900' %>
                <%= f.password_field :password, autocomplete: "current-password",
                  class: 'w-full mt-2 bg-white px-3 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-teal-600 sm:text-sm' %>
              </div>

              <% if devise_mapping.rememberable? %>
                <div class="flex items-start mb-5 mt-4">
                  <div class="group grid size-4 grid-cols-1">
                    <%= f.check_box :remember_me,
                      checked: true,
                      class: 'col-start-1 row-start-1 appearance-none rounded-sm border border-gray-300 bg-white checked:border-indigo-600 checked:bg-indigo-600 indeterminate:border-indigo-600 indeterminate:bg-indigo-600 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 disabled:border-gray-300 disabled:bg-gray-100 disabled:checked:bg-gray-100 forced-colors:appearance-auto' %>

                    <svg class="pointer-events-none col-start-1 row-start-1 size-3.5 self-center justify-self-center stroke-white group-has-disabled:stroke-gray-950/25" viewBox="0 0 14 14" fill="none">
                      <path class="opacity-0 group-has-checked:opacity-100" d="M3 8L6 11L11 3.5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      <path class="opacity-0 group-has-indeterminate:opacity-100" d="M3 7H11" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <%= f.label :remember_me, class: 'ms-2 text-sm font-medium text-gray-900' %>
                </div>
              <% end %>
              <div class="flex flex-col mt-8">
                <%= f.submit t('links.sign_in'),
                  class: 'bg-blue-500 hover:bg-blue-700 text-white text-sm font-semibold py-3 px-4 rounded-sm cursor-pointer' %>
              </div>
            </div>
          <% end %>
          <div class="w-3/4 mx-auto mt-10 text-gray-500 flex items-center justify-center space-x-3">
            <div class="border-t border-gray-400 flex-grow"></div>
            <div>или</div>
            <div class="border-t border-gray-400 flex-grow"></div>
          </div>
          <div class="text-center mt-4">
            <%= link_to new_user_registration_path do %>
              <span class="ml-2 text-sm tracking-wide truncate">Создать новый аккаунт</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
